// QuickBab 데이터 모델
//
// 개발 환경은 SQLite를 사용합니다. Postgres 전환 시:
//  1. datasource provider를 "postgresql"로 변경
//  2. DATABASE_URL을 postgresql:// 로 교체
//  3. 아래 Json-as-String 필드들은 SQLite 호환을 위해 String으로 선언되어
//     있으며 (JSON.stringify 직렬화), Postgres에서는 Json 타입 또는
//     String[] 배열로 마이그레이션할 수 있습니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  profile      DietaryProfile?
  pantryItems  PantryItem[]
  kitchenTools KitchenTool[]
  recipes      Recipe[]
  mealPlans    MealPlan[]
}

model DietaryProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // JSON 배열 문자열, 예: '["땅콩","갑각류"]'
  allergies             String @default("[]")
  religiousRestrictions String @default("[]")
  healthConditions      String @default("[]")

  updatedAt DateTime @updatedAt
}

model PantryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model KitchenTool {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Recipe {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  description    String
  servings       Int
  totalCalories  Int
  targetCalories Int?

  // JSON 직렬화 필드 (Postgres 전환 시 Json 타입 권장)
  ingredients        String // [{name, amount, unit, calories}]
  steps              String // string[]
  usedTools          String // string[]
  missingIngredients String // string[]

  pantryMode  Boolean  @default(false)
  kitchenMode Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model MealPlan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalCalories Int
  // [{meal: "아침"|"점심"|"저녁", calories, suggestion}]
  meals         String
  createdAt     DateTime @default(now())
}
